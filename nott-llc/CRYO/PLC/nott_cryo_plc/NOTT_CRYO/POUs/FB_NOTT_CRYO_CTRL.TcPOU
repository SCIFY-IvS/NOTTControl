<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_NOTT_CRYO_CTRL" Id="{d6e60d4f-f8b6-4737-accb-80f00d84378d}" SpecialFunc="None">
    <Declaration><![CDATA[// NOTT Cryogenic Controller
FUNCTION_BLOCK FB_NOTT_CRYO_CTRL
VAR_INPUT
	in_sName:	STRING := 'NOTT_CRYO_CTRL';	// Control System name
END_VAR
VAR

	///////////////////////////
	// Configuration parameters
	///////////////////////////
	cfg:	T_NOTT_CRYO_CFG;
	
	/////////////////////
	// Control parameters
	/////////////////////
	{attribute 'TcHmiSymbol.Show'}
	ctrl:	T_NOTT_CRYO_CTRL;

	/////////////////////
	// Status parameters
	/////////////////////
	{attribute 'OPC.UA.DA' := '1'}
	{attribute 'OPC.UA.DA.Access' := '1'}
	stat:	T_NOTT_CRYO_STAT;

	/////////////////////
	// Debug parameters
	/////////////////////
	debug:	T_NOTT_CRYO_DEBUG;

	/////////////////////
	// System Triggers
	/////////////////////
	triggers:	T_NOTT_CRYO_TRIGGERS;

	/////////////////////
	// System Events
	/////////////////////
	events:	T_NOTT_CRYO_EVENTS;

	/////////////////////
	// Local variables
	/////////////////////


	//////////////////////////////////////////////
	//             Controllers
	//////////////////////////////////////////////
	{attribute 'TcHmiSymbol.Show'}
	cooler:			FB_METIS_CRYO_CPA;
	

	
	//
	// Heaters
	//
// 	{attribute 'TcHmiSymbol.Show'}
// 	Heater_DetIF:		FB_PDS_CRYO_HEATER_CTRL;
// 	{attribute 'TcHmiSymbol.Show'}
// 	Heater_Preamp:		FB_PDS_CRYO_HEATER_CTRL;
// 	{attribute 'TcHmiSymbol.Show'}
// 	Heater_ColdPlate:	FB_PDS_CRYO_HEATER_CTRL;
// 	
// 	//
// 	// Pointers to System Overrides for control and sensors.
// 	// See M_Configure() for pointer assignments.
// 	//
// 	// Pointers to Overrides of Enable commands for valves, pumps and coolers.
	ptrArr_cor:	ARRAY [0..7] OF POINTER TO FB_CRYO_CMD_OVERRIDE;
	// Pointers to Overrides of Simulation flags for Temperatures.
// 	// Must match indexes of ptrArr_Temp[], see below.
	ptrArr_tor:	ARRAY [0..8] OF POINTER TO FB_CRYO_CMD_OVERRIDE;
// 	// Pointers to Overrides of Simulation flags for Pressures.
	ptrArr_por:	ARRAY [0..1] OF POINTER TO FB_CRYO_CMD_OVERRIDE;
// 	
// 	//
// 	// Indexes for Override GUIs.
// 	//
	guiIndex_cor:	UINT := 0;	// Index for Command Override Engineering GUI
	guiIndex_tor:	UINT := 0;	// Index for Temperature Override Engineering GUI
	guiIndex_por:	UINT := 0;	// Index for Pressure Override Engineering GUI
// 	
// 
	//////////////////////////////////////////////
	//             Subsystems
	//////////////////////////////////////////////

	//
	// Evacuation Subsystem control
	//
	{attribute 'TcHmiSymbol.Show'}
	evac:			FB_NOTT_CRYO_EVAC;	// PDS Evacuation Subsystem
	
	

	//////////////////////////////////////////////
	//             Sensors
	//////////////////////////////////////////////
	// Cryostat Pressure sensors
	sensor_VAGC:	FB_CRYO_SENSOR_PRESSURE;	// Cryo pressure gauge VAGC
	VAGC:			FB_CRYO_PRESSURE_VOTE;		// Cryo pressure C
	
		// Cryostat High Pressure sensor
	sensor_HPG:	FB_CRYO_SENSOR_PRESSURE;	// Cryo pressure gauge VAGC
	HPG:			FB_CRYO_PRESSURE_VOTE;		// Cryo pressure C

	///////////////////////////////////////////////////////
	//                  Temperatures
	///////////////////////////////////////////////////////
 
	{attribute 'OPC.UA.DA' := '1'}
	{attribute 'TcHmiSymbol.Show'}
 	nott_temp:				FB_NOTT_TEMPERATURES;  // All temperature sensors

	
	    /////////////////////////////////////////////////////////
	////                  Voters
	/////////////////////////////////////////////////////////
	{attribute 'OPC.UA.DA' := '1'}
		{attribute 'TcHmiSymbol.Show'}
    nott_voters : FB_NOTT_VOTERS; // All METIS voters

	/////////////////////////////////////////////////////////
	////                  Temperature control
	/////////////////////////////////////////////////////////
	{attribute 'OPC.UA.DA' := '1'}
		{attribute 'TcHmiSymbol.Show'}
// 	nott_tctrl:              FB_NOTT_TCTRL; // All temperature control loops
    
    /////////////////////////////////////////////////////////
	////                  Heaters
	/////////////////////////////////////////////////////////
	{attribute 'OPC.UA.DA' := '1'}
		{attribute 'TcHmiSymbol.Show'}
 	nott_heaters:			FB_NOTT_HEATERS; // All METIS heaters

	/////////////////////////////////////////////////////////
	////                  Temperature control
	/////////////////////////////////////////////////////////
	{attribute 'OPC.UA.DA' := '1'}
		{attribute 'TcHmiSymbol.Show'}
	nott_tctrl:              FB_NOTT_TCTRLs; // All temperature control loops




// 	Temp_Ambient:		FB_CRYO_TEMPERATURE;	// Ambient temperature
// 
// 	Temp_DetMon:		FB_CRYO_TEMPERATURE;	// DET Temperature measured with PT100
// 	Temp_ColdPlate:		FB_CRYO_TEMPERATURE;
// 	Temp_WarmFlange:	FB_CRYO_TEMPERATURE;
// 	Temp_WarmOptics:	FB_CRYO_TEMPERATURE;
// 	// Temperature assigned from the Lakeshore LS336
// 	// using FB_CRYO_TEMPERATURE::M_GetTemperatureFromLakeshore().
// 	// Do not map any signal of this instance.
// 	// See M_ExecuteControllers() for assignment.
// 	Temp_LS336:			FB_CRYO_TEMPERATURE;	
// 
// 
// 	//
// 	// Pointers to Temperatures.
// 	// Must match indexes of ptrArr_tor[], see above.
// 	//
	ptrArr_Temp:	ARRAY [0..8] OF POINTER TO FB_CRYO_TEMPERATURE;
// 	// Pointers to Pressures.
	ptrArr_Press:	ARRAY [0..1] OF POINTER TO FB_CRYO_PRESSURE_VOTE;
// 	
// 	//
// 	// System triggers
// 	//	
	{attribute 'OPC.UA.DA' := '0'}
	trgCool:			R_TRIG;
	{attribute 'OPC.UA.DA' := '0'}
	trgWarmup:			R_TRIG;
	{attribute 'OPC.UA.DA' := '0'}
	trgEvacOn:			R_TRIG;
	{attribute 'OPC.UA.DA' := '0'}
	trgEvacOff:			F_TRIG;

	{attribute 'OPC.UA.DA' := '0'}
	timer:		TON;		// Timer for commands
	
	
	//
	//	Input signals
	//	
	
	
	//
	// Dummy values for simulation, etc.
	//
	// Dummy OP state for mapping of simulated devices.
	q_nStateDummy	AT%Q*:	UINT := 8;		

// 	// HMI Parameters
	hmi_pump_tmp: FB_HMI_CRYO_PUMP;
	hmi_pump_pvp: FB_HMI_CRYO_PUMP;
	hmi_valve_pvv1: FB_HMI_CRYO_VALVE;
	hmi_cooler: FB_HMI_CRYO_HELIUM_COMPRESSOR;
	
	
// 	hmi_lakeshore : FB_HMI_CRYO_LAKESHORE;
// 	hmi_heater_DetIF : FB_HMI_PDS_CRYO_HEATER;
// 	hmi_heater_Preamp : FB_HMI_PDS_CRYO_HEATER;
// 	hmi_heater_ColdPlate : FB_HMI_PDS_CRYO_HEATER;
	hmi_pressure_vote_vagc : FB_HMI_CRYO_PRESSURE_VOTE;
	hmi_pressure_vote_vag1 : FB_HMI_CRYO_PRESSURE_VOTE;
	hmi_pressure_vote_hpg : FB_HMI_CRYO_PRESSURE_VOTE;
// 
// 	hmi_heater_DetIF_temp : FB_HMI_CRYO_TEMPERATURE;
// 	hmi_heater_Preamp_temp : FB_HMI_CRYO_TEMPERATURE;
// 	hmi_heater_Coldplate_temp : FB_HMI_CRYO_TEMPERATURE;

	// Alarm Handling
	fbEventAlarm    : ARRAY[0..2] OF FB_EventAlarm;
	arrAlarmState    : ARRAY[0..2] OF BOOL;
	
	// Cryo System logs
	logs:	FB_CRYO_FUNCTION_LOG;

	
	////////////////////
	//// HMI Screen /// 
	//////////////////

bHMISwitch     AT %I* : BOOL;   // Push button / switch
bHMIOutEnable  AT %Q* : BOOL;   // HMI power output;

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Increment cycle counter
debug.nCycleCounter := debug.nCycleCounter + 1;

//Wait UNTIL the controller is configured.
IF NOT stat.bConfigured THEN
	M_Configure(); 
	RETURN;
END_IF


//
// Read Temperature and Pressure Sensors

M_ReadSensors();


//
// Check for sensor HW errors
//
// M_CheckForSensorErrors();



///////////////////
// System Operation
///////////////////

//
// Execute Controllers
//
M_ExecuteControllers();


//
// Capture system commands
//
M_CheckForCommands();


//
// Perform a safety check
//
M_SafetyCheck();


//
// Check triggers and log events
//
M_ProcessTriggers();

M_ProcessHmi();

//
// Execute system state machine
//
M_StateMachine();

//
// HMI Screen ON/OFF
//
M_HMI_Screen_Control();
]]></ST>
    </Implementation>
    <Method Name="M_CheckForCommands" Id="{b3c6e6aa-1586-4592-991a-74db9a8ffd5e}">
      <Declaration><![CDATA[METHOD M_CheckForCommands
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// Capture Cool command
trgCool(CLK := ctrl.bEnable_Cooler);
IF	trgCool.Q AND stat.nState = E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM THEN
	ctrl.bExecute	:= TRUE;
	ctrl.nCommand	:= E_NOTT_CRYO_CTRL_CMD.COOL;
END_IF


// Capture Warmup command
trgWarmup(CLK := ctrl.bEnable_Warmup);
IF	trgWarmup.Q THEN
	ctrl.bExecute	:= TRUE;
	ctrl.nCommand	:= E_NOTT_CRYO_CTRL_CMD.WARM_UP;
END_IF



// Capture Evacuation ON/OFF trigger
trgEvacOn(CLK := ctrl.bEnable_Evac);
trgEvacOff(CLK := ctrl.bEnable_Evac);
IF	trgEvacOn.Q THEN
	ctrl.bEnable_Evac	:= TRUE;
	logs.M_LogInfo('Evacuation started.');
ELSIF trgEvacOff.Q THEN
	ctrl.bEnable_Evac	:= FALSE;
	logs.M_LogInfo('Evacuation stopped.');
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckForSensorErrors" Id="{e147f220-db5d-4e17-bd45-ee5f80f6f4b1}">
      <Declaration><![CDATA[METHOD M_CheckForSensorErrors
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Don't do any checks on startup.

IF stat.nState = E_NOTT_CRYO_CTRL_STATE.NONE	THEN
	RETURN;
END_IF


////////////////////////////////////////////////
// Check for errors by testing the 'Valid' flag.
////////////////////////////////////////////////
IF		NOT VAGC.stat.bValid	THEN
	stat.bError	:= TRUE;
	stat.sState	:= 'Cryo Vacuum gauge problem';
	IF stat.nState	<> E_NOTT_CRYO_CTRL_STATE.ERROR	THEN
		logs.M_LogInfo('ERROR State: VAGC gauge failure');
	END_IF
	stat.nState	:= E_NOTT_CRYO_CTRL_STATE.ERROR;

ELSE
	stat.bError	:= FALSE;
//	stat.sState	:= '';
END_IF


///////////////////////
// Check for Interlocks
///////////////////////
// TODO

//
// Evacuation and Repressurization are mutually exclusive.
//
// TODO


//
// Disable control in failure state
//
IF stat.bError THEN
	ctrl.bEnable_Cooler 	:= FALSE;
	ctrl.bEnable_Warmup		:= FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckLakeshoreCommand" Id="{be41b795-455d-4af3-b636-24f67650036d}">
      <Declaration><![CDATA[METHOD M_CheckLakeshoreCommand
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* TODO

IF ctrl.bLS_UpdateSETP THEN
Reset trigger flag
	ctrl.bLS_UpdateSETP	:= FALSE;
	
Safety
	IF ctrl.lrLS_RAMP > 1.0 THEN
		ctrl.lrLS_RAMP	:= 1.0;
	ELSIF ctrl.lrLS_RAMP < 0.0 THEN
		ctrl.lrLS_RAMP	:= 0.0;
	END_IF
	
Set the mode
	IF ctrl.nLS_Mode <> E_CRYO_LAKESHORE_MODE.MONITORING THEN
		Lakeshore.M_SetMode(ctrl.nLS_Mode);
	ELSE
		RETURN;	// Nothing to do
	END_IF
ELSE
	RETURN;	// Nothing to do
END_IF




CASE ctrl.nLS_Mode OF
	E_CRYO_LAKESHORE_MODE.MONITORING,
	E_CRYO_LAKESHORE_MODE.COOLING,
	E_CRYO_LAKESHORE_MODE.WARMUP,
	E_CRYO_LAKESHORE_MODE.COOLING_UPDATE,
	E_CRYO_LAKESHORE_MODE.WARMUP_UPDATE:
		Lakeshore.M_SetMode(E_CRYO_LAKESHORE_MODE.MONITORING);	// No action
		
	E_CRYO_LAKESHORE_MODE.SINGLE_SETUP:
		IF stat.nState = E_CRYO_CTRL_STATE.COLD THEN
			Lakeshore.M_SetParams(
				in_nPID_A_P			:= cfg.LS_W_PID_A_P, 
				in_nPID_A_I			:= cfg.LS_W_PID_A_I, 
				in_nPID_A_D			:= cfg.LS_W_PID_A_D, 
				in_nHeater_Range	:= cfg.LS_W_Heater_Range, 
				in_lrCtrlRamp		:= ctrl.lrLS_RAMP, 
				in_lrSetpoint_A		:= ctrl.lrLS_SETP);
		END_IF
	ELSE
		Lakeshore.M_SetMode(E_CRYO_LAKESHORE_MODE.MONITORING);	// No action
END_CASE
*)
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckVacuum" Id="{333e79aa-fbce-4e80-8799-8adf627b68b6}">
      <Declaration><![CDATA[// Method to check status of the cryostat vacuum.
// TODO: The limits might depend on the temperature.
METHOD M_CheckVacuum
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF VAGC.stat.bValid  THEN
	IF VAGC.stat.lrPressure < cfg.lrPress_GoodVac THEN
		stat.bVacuum	:= TRUE;
		stat.bVacuumOK:= TRUE;
	ELSIF VAGC.stat.lrPressure < cfg.lrPress_InVac THEN
		stat.bVacuum	:= TRUE;
		stat.bVacuumOK:= FALSE;
	ELSE
		stat.bVacuum	:= FALSE;
		stat.bVacuumOK:= FALSE;
	END_IF 
ELSE
	stat.bVacuum	:= FALSE;
	stat.bVacuumOK:= FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Configure" Id="{6b1ff45b-ac29-46b7-bfed-5c22653d648f}">
      <Declaration><![CDATA[METHOD M_Configure
VAR_INPUT
END_VAR
VAR
	refBOOL:	REFERENCE TO BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF stat.bConfigured THEN
	RETURN;
ELSIF debug.nCycleCounter = 1 THEN
// THIS call just configures logs AT the very start.
// Logging is done by explicit calls to M_LogInfo().
	logs(in_sName := in_sName);


// Populate arrays of pointers to system functions and sensors.
// Arrays are mostly used in override/sensor GUIs 
// to easily switch to selected system component.

	
	// Set pointers to Temperature readings
// 	ptrArr_Temp[0] := ADR(Temp_Ambient);	
// 	ptrArr_Temp[1] := ADR(Temp_DetMon);	
// 	ptrArr_Temp[2] := ADR(Temp_ColdPlate);	
// 	ptrArr_Temp[3] := ADR(Temp_WarmFlange);	
// 	ptrArr_Temp[4] := ADR(Temp_WarmOptics);	
// 	ptrArr_Temp[5] := ADR(Heater_DetIF.Temp);	
// 	ptrArr_Temp[6] := ADR(Heater_Preamp.Temp);	
// 	ptrArr_Temp[7] := ADR(Heater_ColdPlate.Temp);	
// 	ptrArr_Temp[8] := ADR(Temp_LS336);	

	// Set pointers to Pressure readings
	ptrArr_Press[0] := ADR(VAGC);	
	ptrArr_Press[1] := ADR(evac.VAG1);	

	// Set pointers to command override instances
	ptrArr_cor[0] := ADR(ctrl.cor_Cooler);
	ptrArr_cor[1] := ADR(ctrl.cor_Heater_ColdPlate);
	ptrArr_cor[2] := ADR(ctrl.cor_Heater_IF);
	ptrArr_cor[3] := ADR(ctrl.cor_Heater_Preamp);
	ptrArr_cor[4] := ADR(ctrl.cor_Evac);
	ptrArr_cor[5] := ADR(evac.ctrl.cor_PVP);
	ptrArr_cor[6] := ADR(evac.ctrl.cor_TMP);
	ptrArr_cor[7] := ADR(evac.ctrl.cor_PVV1);
	
	// Set pointers to Overrides of Simulation flags for Temperatures.
// 	ptrArr_tor[0] := ADR(ctrl.tor_Ambient);
// 	ptrArr_tor[1] := ADR(ctrl.tor_DetMon);
// 	ptrArr_tor[2] := ADR(ctrl.tor_ColdPlate);
// 	ptrArr_tor[3] := ADR(ctrl.tor_WarmFlange);
// 	ptrArr_tor[4] := ADR(ctrl.tor_WarmOptics);
// 	ptrArr_tor[5] := ADR(Heater_DetIF.tor_Temp);
// 	ptrArr_tor[6] := ADR(Heater_Preamp.tor_Temp);
// 	ptrArr_tor[7] := ADR(Heater_ColdPlate.tor_Temp);
// 	ptrArr_tor[8] := ADR(ctrl.tor_LS336);
	
// Set pointers to Overrides of Simulation flags for Pressures.
	ptrArr_por[0] := ADR(ctrl.por_VAGC);
	ptrArr_por[1] := ADR(evac.ctrl.por_VAG1);
	
ELSIF debug.nCycleCounter = 2 THEN
// Initialize events
	events.info.CreateEx		(TC_EVENTS.NottCryoSysEventClass.Info,0);
	events.warning.CreateEx		(TC_EVENTS.NottCryoSysEventClass.Warning,0);
	events.error.CreateEx		(TC_EVENTS.NottCryoSysEventClass.Error,FALSE,0);
	events.critical.CreateEx	(TC_EVENTS.NottCryoSysEventClass.Critical,TRUE,0);
	
ELSIF debug.nCycleCounter = 3 THEN
// Put the complete system into simulation
	stat.bSimulation	:= TRUE;

// Temperature Simulation flags
	ctrl.bSim_Temp_Ambient		:= TRUE;
	ctrl.bSim_Temp_DetMon		:= TRUE;
	ctrl.bSim_Temp_ColdPlate	:= TRUE;
	ctrl.bSim_Temp_WarmFlange	:= TRUE;
	ctrl.bSim_Temp_WarmOptics	:= TRUE;
	ctrl.bSim_Temp_LS336		:= TRUE;

// 	refBOOL	REF=Heater_DetIF.bSim_Temp;		refBOOL	:= TRUE;
// 	refBOOL	REF=Heater_Preamp.bSim_Temp;	refBOOL	:= TRUE;	
// 	refBOOL	REF=Heater_ColdPlate.bSim_Temp;	refBOOL	:= TRUE;	
	
// Pressure Simulation flags
	ctrl.bSim_Press_VAGC		:= FALSE;	// The values will come from the simulator.
	refBOOL	REF=evac.ctrl.bSim_Press_VAG1;	refBOOL	:= TRUE;

ELSIF debug.nCycleCounter > 200 THEN
	stat.bConfigured	:= TRUE;
ELSE
	RETURN;
END_IF


]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ExecuteControllers" Id="{ecd9afa5-738c-4753-b62d-612a0c867fca}">
      <Declaration><![CDATA[METHOD M_ExecuteControllers
VAR
	ptrSimTemp:	POINTER TO LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nott_tctrl(temperatures := nott_temp);

nott_heaters(tctrl := nott_tctrl);


// //
// // Controllers, i.e. LN2 cooler, Heater, ...
// //
// 
// // Evacuation subsystem
ctrl.cor_Evac(in_bEnable:=ctrl.bEnable_Evac);
evac(	in_bEnable	:= ctrl.cor_Evac.out_bEnable, 
		in_RefVAGC	:= VAGC);
// 
// 
// 
// 
// 	
// // Cooler
// ctrl.cor_Cooler(in_bEnable:=ctrl.bEnable_Cooler);
// cooler(	in_sName		:= 'Cooler',
// 		in_bSimulation	:= FALSE,
// 		in_bAutoMonitor	:= TRUE,
// 		in_bEnable		:= ctrl.cor_Cooler.out_bEnable);
// 	

	
ctrl.cor_Cooler(in_bEnable:=ctrl.bEnable_Cooler);
Cooler(
	in_bEnable:= ctrl.cor_Cooler.out_bEnable,
	in_bSimulation:= FALSE, 
	in_sName:= 'PTC Cooler', 
	in_sSN_Compressor:= 'CPA28H5W2DNCE-410730000001', 
	in_sSN_PulseTube:= 'PT810-19880200001', 
	in_nYear_Compressor:= 2023, 
	in_nYear_PulseTube:= 2023, 
	in_lrNextService_Compressor:= 20000.0, 
	in_lrNextService_PulseTube:= 40000.0, 
	in_nSlaveID:= 16, 
	in_nPeriod:= 1000);



// // Cooler simulation
// M_SIM_Cooler();
// 
// 		
// 
// //
// // Execute Lakeshore 336 controller
// //
// LS336(	
// 	in_sName			:= 'LS336',
// 	in_bSimulation		:= FALSE,
// 	in_nModel			:= 336,
// 	in_sCmdSuffix		:= '$0A',
// 	in_sReplySuffix		:= '$0A',
// 	in_sDeviceTcpIpAdr	:= '192.168.0.12',
// 	in_nDeviceTcpPort	:= 7777,
// 	in_nPeriod			:= 1000);
// 
// LS336_HMI(in_RefLakeshore := LS336);
// 
// //
// // Assign LS336 readings to the 
// // corresponding FB_CRYO_TEMPERATURE instance.
// //
// // Execute Temperature Override (tor) of simulation flags.
// // ctrl.tor_LS336.out_bEnable overrides the LS336 Simulation flag.
// // ctrl.tor_LS336.out_bEnable = TRUE ==> Simulation active.
// ctrl.tor_LS336	(in_bEnable:=ctrl.bSim_Temp_LS336);
// Temp_LS336(in_sName	:= 'LS336', in_bSimulation := ctrl.tor_LS336.out_bEnable);
// 
// IF NOT ctrl.tor_LS336.out_bEnable	THEN
// 	// Normal mode, i.e., no simulation.
// 	Temp_LS336.M_GetTemperatureFromLakeshore(
// 		bValid	:= (LS336.stat.nErrorCode = 0  AND  
// 					LS336.stat.lrKRDG_A > 0.0  AND 
// 					NOT LS336.bCommProblem),
// 		lrTempK	:= LS336.stat.lrKRDG_A,
// 		lrTempC	:= LS336.stat.lrKRDG_A - 273.15);
// 		
// 	// Assign measured temperature to simulated temperature 
// 	// to avoid jumps when switching to simulation.
// 	ptrSimTemp	:= ADR(Temp_LS336.stat.lrSimTempK);
// 	ptrSimTemp^	:= LS336.stat.lrKRDG_A;
// END_IF


// //
// // Heaters
// //
// ctrl.cor_Heater_IF(in_bEnable:=ctrl.bEnable_Heaters);
// Heater_DetIF(
// 	in_sName	:= 'H_DetIF',
// 	in_bEnable	:= ctrl.cor_Heater_IF.out_bEnable,
// 	in_nType	:= E_PDS_CRYO_HEATER_CTRL.DET_IF, 
// 	in_nSysState:= stat.nState,
// 	in_RefTemp	:= Temp_DetMon,			// Reference temperature is of Detector Monitor.
// 	in_lrPar1	:= cfg.lrTemp_Target);	// Target Detector Interface temperature 75K.
// 	
// ctrl.cor_Heater_Preamp(in_bEnable:=ctrl.bEnable_Heaters);
// Heater_Preamp(	 
// 	in_sName	:= 'H_Preamp',
// 	in_bEnable	:= ctrl.cor_Heater_Preamp.out_bEnable,
// 	in_nType	:= E_PDS_CRYO_HEATER_CTRL.PREAMP, 
// 	in_nSysState:= stat.nState,
// 	in_RefTemp	:= Heater_DetIF.Temp,	// Reference temperature is of Detector Interface.
// 	in_lrPar1	:= cfg.lrTemp_Preamp);	// Preamp temperature 120K.
// 	
// ctrl.cor_Heater_ColdPlate(in_bEnable:=ctrl.bEnable_Heaters);
// Heater_ColdPlate(	 
// 	in_sName	:= 'H_ColdPlate',
// 	in_bEnable	:= ctrl.cor_Heater_ColdPlate.out_bEnable,
// 	in_nType	:= E_PDS_CRYO_HEATER_CTRL.COLD_PLATE, 
// 	in_nSysState:= stat.nState,
// 	in_RefTemp	:= Heater_DetIF.Temp);	// Reference temperature is of Detector Interface.
	

//
// All temperatures are known.
// Select the Master temperature
//
M_GetMasterTemp();


//
// Get the lowest temperature in the cryostat
//	
M_GetLowestTemperature();

//
// Get the highest temperature in the cryostat
//	
M_GetHighestTemperature();
	


	]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetHighestTemperature" Id="{f099693e-d874-48c5-b3ed-d3d7c79c242b}">
      <Declaration><![CDATA[METHOD M_GetHighestTemperature
VAR_INPUT
END_VAR
VAR
	lrTempK:	LREAL	:= 0.0;	// The lowest possible temperature
	bValid:		BOOL	:= FALSE;
	i:			INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// //
// // Get the higest temperature in the system, 
// // excluding the Ambient temperature.
// //
// // See M_Configure for indexes [0..8].
// //    Ambient, index 0, skip it.
// //
