// refCoolerStat.nErrorCode	:= 0;
// refCoolerStat.lrTempReject	:= 21.4;
// // Simulated temperature close to DET I/F temperature.
// refCoolerStat.lrTempColdHead:= Heater_DetIF.Temp.stat.lrTempK - 0.1;
// IF cooler.in_bEnable	THEN
// 	refCoolerStat.bActive	:= TRUE;
// 	refCoolerStat.nDevState	:= E_CRYO_CRYOTELGT_STATE.ON;
// ELSE
// 	refCoolerStat.bActive	:= FALSE;
// 	refCoolerStat.nDevState	:= E_CRYO_CRYOTELGT_STATE.OFF;
// END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_StateMachine" Id="{f7bc139f-316a-4d67-87a9-8a35421cffa4}">
      <Declaration><![CDATA[METHOD M_StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[////////////////
// State Machine
////////////////
CASE stat.nState OF
	/////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.NONE:
	/////////////////////////////////
	//
	// This is the state on power-up.
	// Determine the initial state based on the command and actuator state.
	M_GetState();	
	RETURN;
	

	/////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.WARM_PRESS:
	/////////////////////////////////
	//
	ctrl.bSafe_Cooling	:= FALSE;
	ctrl.bSafe_Warmup	:= FALSE;

	ctrl.bEnable_Cooler		:= FALSE;
	ctrl.bEnable_Heaters	:= FALSE;

	IF	ctrl.bExecute	THEN
		ctrl.bExecute		:= FALSE;
		stat.nLastCommand	:= ctrl.nCommand;
		ctrl.nCommand		:= E_NOTT_CRYO_CTRL_CMD.NONE;
	ELSIF VAGC.stat.lrPressure < cfg.lrPress_InVac THEN
		// Evacuation is not part of the State Machine.
		// Once the air has been evacuated, we switch to WARM_VACUUM.
		// In WARM_VACUUM, Cooler and Heater should be OFF.
		// They are enabled on command.
		ctrl.bEnable_Cooler		:= FALSE;
		ctrl.bEnable_Heaters	:= FALSE;

		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
	END_IF
	M_SetStatus(stat.nState);	
	RETURN;
	
	
	//////////////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM:
	//////////////////////////////////////////
	//
	ctrl.bSafe_Cooling	:= stat.bCoolantFlowOK  AND  stat.bVacuumOK;
	ctrl.bSafe_Warmup	:= TRUE;
	
	IF	ctrl.bExecute	THEN
		ctrl.bExecute		:= FALSE;
		stat.nLastCommand	:= ctrl.nCommand;
		ctrl.nCommand		:= E_NOTT_CRYO_CTRL_CMD.NONE;
		IF stat.nLastCommand = E_NOTT_CRYO_CTRL_CMD.COOL	THEN
			// Cool down only if the coolant flow is OK
			IF stat.bCoolantFlowOK	THEN
				logs.M_LogInfo('Cool-down started.');
				// Turn ON the cooler
				ctrl.bEnable_Cooler	:= TRUE;
				// Activate heaters in order to control the cooling rate
				ctrl.bEnable_Heaters:= TRUE;
				// Enable Evacuation
				ctrl.bEnable_Evac	:= TRUE;
				// Switch to CoolingDown state.
				stat.nState	:= E_NOTT_CRYO_CTRL_STATE.COOLING_DOWN;
			ELSE
				logs.M_LogInfo('Coolant flow too low. COOL command rejected!');
				
			END_IF
		ELSIF stat.nLastCommand = E_NOTT_CRYO_CTRL_CMD.WARM_UP	THEN
			// Enable Evacuation.
			ctrl.bEnable_Evac	:= TRUE;
			// Activate heaters to control temperature ramps and differences
			ctrl.bEnable_Heaters:= TRUE;
			// Stop the cooler.
			ctrl.bEnable_Cooler	:= FALSE;

			logs.M_LogInfo('Warm-up started.');
			stat.nState	:= E_NOTT_CRYO_CTRL_STATE.WARMING_UP;
		END_IF
	ELSIF VAGC.stat.lrPressure >= cfg.lrPress_InVac THEN
		// The pressure in the cryostat has increased above 
		// the in-vacuum threshold for some reason.
		// Switch to WARM_PRESS (warm pressurized).
		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_PRESS;
	END_IF
	M_SetStatus(stat.nState);	
	RETURN;
	

	///////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.COOLING_DOWN:
	///////////////////////////////////
	//
	ctrl.bSafe_Cooling		:= TRUE;
	ctrl.bSafe_Warmup		:= NOT ctrl.bEnable_Cooler;
	
	IF stat.lrMasterTempK < cfg.lrTemp_OP	THEN
		logs.M_LogInfo('Temperature below OP threshold. State is COLD.');
		// Enable Evacuation
		ctrl.bEnable_Evac	:= TRUE;
		// Activate heaters in order to control the cooling rate
		ctrl.bEnable_Heaters:= TRUE;
		// Switch to Cold state.
		stat.nState	:= E_NOTT_CRYO_CTRL_STATE.COLD;
	ELSIF NOT ctrl.bEnable_Cooler THEN
		// Cooling has been interrupted.
		// Go back to WARM_VACUUM state.
		
		// Turn OFF heaters.
		ctrl.bEnable_Heaters:= FALSE;
		
		logs.M_LogInfo('Cooling interrupted. State is WARM_VACUUM.');
		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
	ELSIF NOT stat.bCoolantFlowOK THEN
		// No coolant flow. Stop the cooler.
		// Go back to WARM_VACUUM state.
		ctrl.bEnable_Cooler		:= FALSE;

		// Turn OFF heaters.
		ctrl.bEnable_Heaters:= FALSE;
		
		logs.M_LogInfo('Low coolant flow. Cooling interrupted. State is WARM_VACUUM.');
		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
	END_IF
	M_SetStatus(stat.nState);	
	RETURN;
	
	
	///////////////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.COLD:
	///////////////////////////////////////////
	//
	ctrl.bSafe_Cooling	:= stat.bCoolantFlowOK;
	ctrl.bSafe_Warmup	:= TRUE;

	//
	// Only WARM_UP command is allowed in state COLD.
	// Other commands are ignored.
	//
	IF	ctrl.bExecute	THEN
		ctrl.bExecute		:= FALSE;
		stat.nLastCommand	:= ctrl.nCommand;
		ctrl.nCommand		:= E_NOTT_CRYO_CTRL_CMD.NONE;
		IF stat.nLastCommand = E_NOTT_CRYO_CTRL_CMD.WARM_UP	THEN
			// Enable Evacuation.
			ctrl.bEnable_Evac	:= TRUE;
			// Activate heaters to control temperature ramps and differences
			ctrl.bEnable_Heaters:= TRUE;
			// Stop the cooler.
			ctrl.bEnable_Cooler	:= FALSE;

			logs.M_LogInfo('Warm-up started.');
			stat.nState	:= E_NOTT_CRYO_CTRL_STATE.WARMING_UP;
		END_IF
	ELSIF NOT stat.bCoolantFlowOK THEN
		// No coolant flow. Stop the cooler.
		IF ctrl.bEnable_Cooler	THEN
			logs.M_LogInfo('Coolant flow too low. Cooling interrupted. State remains COLD.');
		END_IF
		ctrl.bEnable_Cooler		:= FALSE;
	ELSIF stat.lrMasterTempK >= cfg.lrTemp_Cold	THEN
		logs.M_LogInfo('Temperature increase. Not COLD any more. Switching to WARM_VACUUM.');
		// Enable Evacuation Valve control
		ctrl.bEnable_Evac	:= TRUE;
		stat.nState	:= E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
	ELSIF 	ctrl.bEnable_Cooler = TRUE  AND  
			stat.lrMasterTempK < cfg.lrTemp_LowLimit	THEN
		// Temperature too low (<73K). Stop the cooler.
		logs.M_LogInfo('Temperature too low. Safety action: Cooler OFF.');
		ctrl.bEnable_Cooler		:= FALSE;
	ELSIF	ctrl.bEnable_Cooler = FALSE  AND  
			stat.lrMasterTempK > (cfg.lrTemp_LowLimit + 3.0)	AND  
			stat.lrMasterTempK < (cfg.lrTemp_LowLimit + 8.0)	THEN
		// Temperature increasing (>76K). 
		// Start the cooler if close to target temperature.
		logs.M_LogInfo('Temperature too high. Safety action: Cooler ON.');
		ctrl.bEnable_Cooler	:= TRUE;
	END_IF
	M_SetStatus(stat.nState);	
	RETURN;
	
	/////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.WARMING_UP:
	/////////////////////////////////
	//
	ctrl.bSafe_Cooling	:= FALSE;

	IF NOT ctrl.bEnable_Warmup THEN
		// Warming up has been interrupted by the user.
		IF stat.lrMasterTempK > cfg.lrTemp_Cold	THEN
			// Deactivate heaters
			ctrl.bEnable_Heaters:= FALSE;
			// Stop the cooler (just in case).
			ctrl.bEnable_Cooler	:= FALSE;
			// Go back to WARM_VACUUM state.
			logs.M_LogInfo('Warming up interrupted. State is WARM_VACUUM.');
			stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
		ELSE
			// Enable Evacuation
			ctrl.bEnable_Evac	:= TRUE;
			// Activate heaters in order to control the cooling rate
			ctrl.bEnable_Heaters:= TRUE;
			// Go back to COLD state.
			logs.M_LogInfo('Warming up interrupted. State is COLD.');
			stat.nState := E_NOTT_CRYO_CTRL_STATE.COLD;
		END_IF
	END_IF
	M_SetStatus(stat.nState);	
	RETURN;
	
	
	/////////////////////////////////
	E_NOTT_CRYO_CTRL_STATE.ERROR:
	/////////////////////////////////
	//
	// RESET the controller in order to try to 
	// restart the system and clear the error.
	//
	IF ctrl.bReset THEN
		ctrl.bReset			:= FALSE;	// Clear RESET flag
		stat.bSystemStarted	:= FALSE;	// This will introduce 10s delay on startup.
		// Goto NONE state that will execute M_GetState().
		stat.nState	:= E_NOTT_CRYO_CTRL_STATE.NONE;
		M_SetStatus(stat.nState);	
	ELSIF NOT stat.bError  THEN
		// Goto NONE state
		stat.nState	:= E_NOTT_CRYO_CTRL_STATE.NONE;
		M_SetStatus(stat.nState);	
	END_IF
	RETURN;

END_CASE]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>