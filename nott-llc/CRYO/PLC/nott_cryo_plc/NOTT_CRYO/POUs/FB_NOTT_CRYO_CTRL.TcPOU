    </Method>
    <Method Name="M_GetMasterTemp" Id="{9f658211-f955-49ef-a8cf-c1aa3c505951}">
      <Declaration><![CDATA[//
// By default,  master temperature is the one from Heater_DetIF.
// However, if this sensor fails, the system will select another
// sensor in the following order:
//  - Lakeshore
//  - Temp_DetMon
//
METHOD M_GetMasterTemp
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//
// Take the first valid temperature reading as the master temperature.
// Attribute stat.nMasterTempKIndex is only used to turn ON corresponding LED 
// on the GUI_PDS_CRYO GUI.
//
// IF Heater_DetIF.Temp.stat.bValid	THEN
// 	stat.lrMasterTempK	:= Heater_DetIF.Temp.stat.lrTempK;
// 	stat.nMasterTempKIndex := 0;
// ELSIF Temp_LS336.stat.bValid	THEN
// 	stat.lrMasterTempK	:= Temp_LS336.stat.lrTempK;
// 	stat.nMasterTempKIndex := 1;
// ELSIF Temp_DetMon.stat.bValid	THEN
// 	stat.lrMasterTempK	:= Temp_DetMon.stat.lrTempK;
// 	stat.nMasterTempKIndex := 2;
// ELSE
// 	// None of the reference temperatures is valid.
// 	// Set master temperature to the conventional invalid value. 
// 	stat.lrMasterTempK	:= 850.0;
// 	stat.nMasterTempKIndex := 0;
// END_IF

//
// Update the cryostat temperature status.
//
// IF stat.lrMasterTempK < cfg.lrTemp_OP	THEN
// 	stat.bCold	:= TRUE;
// 	stat.bOP	:= TRUE;
// ELSIF stat.lrMasterTempK < cfg.lrTemp_Cold	THEN
// 	stat.bCold	:= TRUE;
// 	stat.bOP	:= FALSE;
// ELSE
// 	stat.bCold	:= FALSE;
// 	stat.bOP	:= FALSE;
// END_IF
// RETURN;

(********************************
***********************************
***********************************
******** Test temp Change it when temp sensors are available
********************************
******************************************************)

	stat.lrMasterTempK	:= 301;
	stat.nMasterTempKIndex := 0;
	

	stat.bCold	:= FALSE;
	stat.bOP	:= FALSE;

	
		

(*******************
*******************
***************)
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetState" Id="{5a884a9e-ba07-433e-b2f1-a9a097b44b59}">
      <Declaration><![CDATA[METHOD M_GetState
VAR_INPUT
END_VAR
VAR_INST
	timer:		TON;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Determine the initial state based on the command and actuator state.

// Firstly wait for the complete system to start.
// Serial port devices need about seven seconds to initialise.
// We wait 10 sec to avoid going into Error state on startup.
//
IF NOT stat.bSystemStarted	THEN
	// Start the 10s timer
	timer(IN:=FALSE);
	timer(IN:=TRUE, PT:=T#10S);
	stat.bSystemStarted	:= TRUE;
	stat.sState	:= 'Starting...';
	RETURN;
END_IF

timer();

// IF timer.Q	THEN
// 	timer(IN:=FALSE);	// Reset the timer
// 	
// 	// 10S have expired.
// 	// Find the system state based of sensor eadings.
// 	IF Heater_DetIF.Temp.stat.lrTempK <= cfg.lrTemp_Cold	THEN
// 		logs.M_LogInfo('On restart, System is COLD.');
// 		// Turn ON the cooler if coolant flow is OK
// 		IF stat.bCoolantFlowOK	THEN
// 			ctrl.bEnable_Cooler	:= TRUE;
// 		END_IF
// 		// Enable Evacuation
// 		ctrl.bEnable_Evac	:= TRUE;
// 		// Activate heaters in order to control the cooling rate
// 		ctrl.bEnable_Heaters:= TRUE;
// 		logs.M_LogInfo('System started in state COLD');
// 		// Switch to Cold state.
// 		stat.nState	:= E_NOTT_CRYO_CTRL_STATE.COLD;
// 	ELSIF 	Heater_DetIF.Temp.stat.lrTempK > cfg.lrTemp_Cold	AND 
// 			VAGC.stat.lrPressure <= cfg.lrPress_InVac				THEN
// 		// Enable Evacuation
// 		ctrl.bEnable_Evac		:= TRUE;
// 		// Stop Cooler.
// 		ctrl.bEnable_Cooler		:= FALSE;
// 		// Turn OFF the heaters.
// 		ctrl.bEnable_Heaters	:= FALSE;
// 		logs.M_LogInfo('System started in state WARM_VACUUM');
// 
// 		// The system is in WARM_VACUUM.
// 		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM;
// 	ELSIF 	Heater_DetIF.Temp.stat.lrTempK > cfg.lrTemp_Cold	AND 
// 			VAGC.stat.lrPressure > cfg.lrPress_InVac				THEN
// 		// Stop Evacuation.
// 		ctrl.bEnable_Evac	:= FALSE;
// 		// Stop Cooler.
// 		ctrl.bEnable_Cooler		:= FALSE;
// 		// Turn OFF the heaters.
// 		ctrl.bEnable_Heaters	:= FALSE;
// 		logs.M_LogInfo('System started in state WARM_PRESS');
// 
// 		// The system is in WARM_PRESS.
// 		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_PRESS;
// 	ELSE
		// Stop Evacuation.
		ctrl.bEnable_Evac	:= FALSE;
		// Stop Cooler.
		ctrl.bEnable_Cooler		:= FALSE;
		// Turn OFF the heaters.
		ctrl.bEnable_Heaters	:= FALSE;
		logs.M_LogInfo('System started in state WARM_PRESS');

		// The system is in WARM_PRESS.
		stat.nState := E_NOTT_CRYO_CTRL_STATE.WARM_PRESS;
// 	END_IF	
// ELSE
// 	stat.sState	:= 'Starting...';
// END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_HMI_Screen_Control" Id="{45acb9a9-844b-46fb-8751-2c8819581c4f}">
      <Declaration><![CDATA[METHOD M_HMI_Screen_Control : BOOL
VAR_INPUT
END_VAR
VAR_INST
    trigHMISwitch : R_TRIG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_HMI_Screen_Control := TRUE;

////////////////////
/// HMI Screen   ///
////////////////////

// Rising edge detection
trigHMISwitch(CLK := bHMISwitch);

// Toggle HMI power output
IF trigHMISwitch.Q THEN
    bHMIOutEnable := NOT bHMIOutEnable;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ProcessHmi" Id="{e3cb379d-3813-454d-a3fb-346b114f3b4b}">
      <Declaration><![CDATA[METHOD PRIVATE M_ProcessHmi]]></Declaration>
      <Implementation>
        <ST><![CDATA[hmi_pump_tmp(
	inout_sPumpStatRef := evac.pump_tmp.stat,
	inout_sCmdOver := evac.ctrl.cor_TMP,
	inout_fbAlarmHandlerRef := evac.pump_tmp.fbAlarmHandler
	);

hmi_pump_pvp(
	inout_sPumpStatRef := evac.pump_pvp.stat,
	inout_sCmdOver := evac.ctrl.cor_PVP,
	inout_fbAlarmHandlerRef := evac.pump_pvp.fbAlarmHandler
	);

hmi_valve_pvv1(
	inout_sValveStatRef := evac.PVV1.stat,
	inout_sCmdOver := evac.ctrl.cor_PVV1,
	inout_fbAlarmHandlerRef := evac.PVV1.fbAlarmHandler,
	);

// hmi_cooler(
// 	inout_sCoolerStatRef := cooler.stat,
// 	inout_sCmdOver := ctrl.cor_Cooler,
// 	inout_fbAlarmHandlerRef := cooler.fbAlarmHandler
// 	);
	
hmi_cooler(inout_sCpaStatRef:= cooler.stat, inout_sCmdOver:= ctrl.cor_Cooler, out_stat=> );

// hmi_lakeshore(
// 	inout_sLakeshoreStatRef := LS336_HMI.stat,
// 	inout_fbAlarmHandlerRef := LS336_HMI.fbAlarmHandler
// 	);
// 
// hmi_heater_DetIF(
// 	inout_sHeaterStatRef := Heater_DetIF.stat,
// 	inout_sCmdOver := ctrl.cor_Heater_IF,
// 	inout_fbAlarmHandlerRef := Heater_DetIF.fbAlarmHandler
// 	);
// 
// hmi_heater_Preamp(
// 	inout_sHeaterStatRef := Heater_Preamp.stat,
// 	inout_sCmdOver := ctrl.cor_Heater_Preamp,
// 	inout_fbAlarmHandlerRef := Heater_Preamp.fbAlarmHandler
// 	);
// 
// hmi_heater_ColdPlate(
// 	inout_sHeaterStatRef := Heater_ColdPlate.stat,
// 	inout_sCmdOver := ctrl.cor_Heater_ColdPlate,
// 	inout_fbAlarmHandlerRef := Heater_ColdPlate.fbAlarmHandler
// 	);

hmi_pressure_vote_vagc(
	inout_sPressureVoteStatRef := VAGC.stat,
	inout_sCmdOver := ctrl.por_VAGC,
	inout_fbAlarmHandlerRef := VAGC.fbAlarmHandler
	);

hmi_pressure_vote_vag1(
	inout_sPressureVoteStatRef := evac.pump_pvp.VAG1_stat,
	inout_sCmdOver := evac.ctrl.por_VAG1,
	inout_fbAlarmHandlerRef := evac.VAG1.fbAlarmHandler
	);
hmi_pressure_vote_hpg(
	inout_sPressureVoteStatRef := HPG.stat,
	inout_sCmdOver := ctrl.por_HPG,
	inout_fbAlarmHandlerRef := HPG.fbAlarmHandler
	);

// hmi_heater_DetIF_temp(
// 	inout_sTemperatureStatRef := Heater_DetIF.Temp.stat,
// 	inout_sCmdOver := Heater_DetIF.tor_Temp,
// 	inout_fbAlarmHandlerRef := Heater_DetIF.Temp.fbAlarmHandler
// 	);
// 
// hmi_heater_Preamp_temp(
// 	inout_sTemperatureStatRef := Heater_Preamp.Temp.stat,
// 	inout_sCmdOver := Heater_Preamp.tor_Temp,
// 	inout_fbAlarmHandlerRef := Heater_Preamp.Temp.fbAlarmHandler
// 	);
// 
// hmi_heater_Coldplate_temp(
// 	inout_sTemperatureStatRef := Heater_Coldplate.Temp.stat,
// 	inout_sCmdOver := Heater_Coldplate.tor_Temp,
// 	inout_fbAlarmHandlerRef := Heater_Coldplate.Temp.fbAlarmHandler
// 	);]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ProcessTriggers" Id="{926bb19b-2599-4262-b7c1-df02cad83bab}">
      <Declaration><![CDATA[METHOD M_ProcessTriggers
VAR_INPUT
END_VAR
VAR
    fbFormat:	FB_FormatString;
	sOut:		STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//
// Check triggers and log corresponding events.
//

//
// Cooler
//
// triggers.Cooler_Enable		(CLK := cooler.in_bEnable);
// triggers.Cooler_Disable		(CLK := cooler.in_bEnable);
// triggers.Cooler_ON			(CLK := (cooler.stat.nDevState = E_CRYO_CRYOTELGT_STATE.ON));
// triggers.Cooler_OFF			(CLK := (cooler.stat.nDevState = E_CRYO_CRYOTELGT_STATE.OFF));
// 
// IF triggers.Cooler_Enable.Q	THEN
// 	logs.M_LogInfo('Cooler Starting...');
// ELSIF triggers.Cooler_Disable.Q	THEN
// 	logs.M_LogInfo('Cooler Stopping...');
// ELSIF triggers.Cooler_ON.Q	THEN
// 	logs.M_LogInfo('Cooler ON');
// ELSIF triggers.Cooler_OFF.Q	THEN
// 	logs.M_LogInfo('Cooler OFF');
// END_IF


//
// Pressure and Temperature status flags
//

// Vacuum
triggers.Vacuum_ON		(CLK := stat.bVacuum);
triggers.Vacuum_OFF		(CLK := stat.bVacuum);
triggers.Vacuum_OK		(CLK := stat.bVacuumOK);
triggers.Vacuum_NOT_OK	(CLK := stat.bVacuumOK);

IF triggers.Vacuum_ON.Q	THEN
	logs.M_LogInfo('In Vacuum');
ELSIF triggers.Vacuum_OFF.Q	THEN
	logs.M_LogInfo('NOT In Vacuum');
ELSIF triggers.Vacuum_OK.Q	THEN
	logs.M_LogInfo('Vacuum OK');
ELSIF triggers.Vacuum_NOT_OK.Q	THEN
	logs.M_LogInfo('Vacuum NOT OK');
END_IF


// Temperature
triggers.Cold_ON		(CLK := stat.bCold);
triggers.Cold_OFF		(CLK := stat.bCold);
triggers.OP_ON			(CLK := stat.bOP);
triggers.OP_OFF			(CLK := stat.bOP);

IF triggers.Cold_ON.Q	THEN
	logs.M_LogInfo('System is COLD');
ELSIF triggers.Cold_OFF.Q	THEN
	logs.M_LogInfo('System is NOT COLD');
ELSIF triggers.OP_ON.Q	THEN
	logs.M_LogInfo('System is OPERATIONAL');
ELSIF triggers.OP_OFF.Q	THEN
	logs.M_LogInfo('System is NOT OPERATIONAL');
END_IF


	
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ReadSensors" Id="{672cff29-2690-4702-a7ba-5d0f0ce7deac}">
      <Declaration><![CDATA[METHOD M_ReadSensors
VAR_INPUT
END_VAR
VAR
	refBOOL:	REFERENCE TO BOOL;
	refLREAL:	REFERENCE TO LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//
// Read system temperatures.
//

nott_temp();

// Update the voters
nott_voters(nott_temp := nott_temp);



// Execute Temperature Override (tor) of simulation flags.
// ctrl.tor_Ambient	(in_bEnable:=ctrl.bSim_Temp_Ambient);
// ctrl.tor_DetMon		(in_bEnable:=ctrl.bSim_Temp_DetMon);
// ctrl.tor_ColdPlate	(in_bEnable:=ctrl.bSim_Temp_ColdPlate);
// ctrl.tor_WarmFlange	(in_bEnable:=ctrl.bSim_Temp_WarmFlange);
// ctrl.tor_WarmOptics	(in_bEnable:=ctrl.bSim_Temp_WarmOptics);
// 
// Temp_Ambient	(in_sName := 'T_Ambient',		in_bSimulation := ctrl.tor_Ambient.out_bEnable);
// Temp_DetMon		(in_sName := 'T_DetMon',		in_bSimulation := ctrl.tor_DetMon.out_bEnable);	
// Temp_ColdPlate	(in_sName := 'T_ColdPlate',		in_bSimulation := ctrl.tor_ColdPlate.out_bEnable);
// Temp_WarmFlange	(in_sName := 'T_WarmFlange',	in_bSimulation := ctrl.tor_WarmFlange.out_bEnable);
// Temp_WarmOptics	(in_sName := 'T_WarmOptics',	in_bSimulation := ctrl.tor_WarmOptics.out_bEnable);



// Calculate temperature differences.
// Temperature difference between DET (Lakeshore) and DET (PT100).
// stat.lrTempDiff_DET_Mon			:= Temp_LS336.stat.lrTempK        - Temp_DetMon.stat.lrTempK;	
// stat.lrTempDiff_DetIF_Mon		:= Heater_DetIF.Temp.stat.lrTempK - Temp_DetMon.stat.lrTempK;	
// stat.lrTempDiff_DetIF_Preamp	:= Heater_DetIF.Temp.stat.lrTempK - Heater_Preamp.Temp.stat.lrTempK;	
// stat.lrTempDiff_DetIF_ColdPlate	:= Heater_DetIF.Temp.stat.lrTempK - Heater_ColdPlate.Temp.stat.lrTempK;	
// stat.lrTempDiff_DetIF_WarmFlange:= Heater_DetIF.Temp.stat.lrTempK - Temp_WarmFlange.stat.lrTempK;
// stat.lrTempDiff_DetIF_WarmOptics:= Heater_DetIF.Temp.stat.lrTempK - Temp_WarmOptics.stat.lrTempK;


// NOTT Cryostat pressure.

// Sensor instance
// Average over 1 sec (1000 ms).
sensor_VAGC(
	in_sName := 'VAGC_S1',
	in_nType		:= E_CRYO_SENSOR_TYPE_PRESS.PKR_360,	
	in_nSampleTime	:= 1000);

// VAGC Pressure Voting system (one sensor only!)
ctrl.por_VAGC(in_bEnable := ctrl.bSim_Press_VAGC);
VAGC(
	in_sName := 'VAGC',
	in_bSimulation	:= ctrl.por_VAGC.out_bEnable,
// In reality, there is only one pressure sensor connected (sensor_VAGC)
	in_nNumSensor	:= 2,	
	in_nVoteMethod	:= E_CRYO_VOTE.V_1oo2,
	in_pSensor1		:= ADR(sensor_VAGC));
	
sensor_HPG(
	in_sName := 'HPG_S1',
	in_nType		:= E_CRYO_SENSOR_TYPE_PRESS.CMR_361,	
	in_nSampleTime	:= 1000);

//VAGC Pressure Voting system (one sensor only!)
ctrl.por_HPG(in_bEnable := ctrl.bSim_Press_HPG);
HPG(
	in_sName := 'HPG',
	in_bSimulation	:= ctrl.por_HPG.out_bEnable,
// In reality, there is only one pressure sensor connected (sensor_VAGC)
	in_nNumSensor	:= 2,	
	in_nVoteMethod	:= E_CRYO_VOTE.V_1oo2,
	in_pSensor1		:= ADR(sensor_HPG));





//
// Check Vacuum in the system
//	
M_CheckVacuum();
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SafetyCheck" Id="{bb820798-874a-468f-852d-2934989cda4b}">
      <Declaration><![CDATA[METHOD M_SafetyCheck
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// TODO if any

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetStatus" Id="{f025e401-b414-44ce-9499-c12078610b3c}">
      <Declaration><![CDATA[METHOD M_SetStatus
VAR_INPUT
	nState:	E_NOTT_CRYO_CTRL_STATE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE nState OF
	
	E_NOTT_CRYO_CTRL_STATE.NONE:
	stat.bDone	:= TRUE;
	stat.bBusy	:= FALSE;
	stat.bError	:= FALSE;
	stat.bActive:= FALSE;
	stat.sState	:= 'OFF';
	
	E_NOTT_CRYO_CTRL_STATE.WARM_PRESS:
	stat.bDone	:= TRUE;
	stat.bBusy	:= FALSE;
	stat.bError	:= FALSE;
	stat.bActive:= TRUE;
	stat.sState	:= 'WARM - PRESSURIZED';
	
	E_NOTT_CRYO_CTRL_STATE.WARM_VACUUM:
	stat.bDone	:= TRUE;
	stat.bBusy	:= FALSE;
	stat.bError	:= FALSE;
	stat.bActive:= TRUE;
	stat.sState	:= 'WARM - VACUUM';
	

	E_NOTT_CRYO_CTRL_STATE.COOLING_DOWN:
	stat.bDone	:= FALSE;
	stat.bBusy	:= TRUE;
	stat.bError	:= FALSE;
	stat.bActive:= TRUE;
	stat.sState	:= 'COOLING DOWN...';

	E_NOTT_CRYO_CTRL_STATE.COLD:
	stat.bDone	:= TRUE;
	stat.bBusy	:= FALSE;
	stat.bError	:= FALSE;
	stat.bActive:= TRUE;
	stat.sState	:= 'COLD';

	E_NOTT_CRYO_CTRL_STATE.WARMING_UP:
	stat.bDone	:= FALSE;
	stat.bBusy	:= TRUE;
	stat.bError	:= FALSE;
	stat.bActive:= TRUE;
	stat.sState	:= 'WARMING UP...';
	
	// TODO
	// Select reference temperature for warmup
	//
	(*
	IF Temp_Mirror.stat.lrTempK >= cfg.lrTemp_Warm	THEN
		stat.sState	:= 'WARM';
	ELSIF	Temp_Mirror.stat.lrTempK < cfg.lrTemp_Warm AND
			Temp_Mirror.stat.lrTempK >= cfg.lrTemp_Precooled	THEN
		stat.sState	:= 'WARMING UP... PRE-COOLED';
	ELSE
		stat.sState	:= 'WARMING UP... COLD';
	END_IF
	*)

	
	E_NOTT_CRYO_CTRL_STATE.ERROR:
	stat.bDone	:= TRUE;
	stat.bBusy	:= FALSE;
	stat.bError	:= TRUE;
	stat.bActive:= FALSE;
	stat.sState	:= 'ERROR';

END_CASE

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SIM_Cooler" Id="{09433411-2c0e-4aeb-89e1-a57a3a561dab}">
      <Declaration><![CDATA[METHOD M_SIM_Cooler
VAR_INPUT
END_VAR
VAR
	refCoolerStat:	REFERENCE TO T_CRYO_CRYOTELGT_STAT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// // Simulated values
