// 	IF ptrArr_Temp[i]^.stat.bValid	THEN
// 		IF ptrArr_Temp[i]^.stat.lrTempK > lrTempK	THEN
// 			lrTempK	:= ptrArr_Temp[i]^.stat.lrTempK;
// 			bValid	:= TRUE;
// 		END_IF
// 	END_IF
// END_FOR
// 
// 
// // Update status
// stat.lrHighestTempK		:= lrTempK;
// stat.bHighestTempValid	:= bValid;

(********************************
***********************************
***********************************
******** Test temp Change it when temp sensors are available
********************************
******************************************************)

stat.lrHighestTempK		:= 301;
stat.bHighestTempValid	:= bValid;

	
		

(*******************
*******************
***************)]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetLowestTemperature" Id="{bf361e98-30dd-4e82-9d81-54c9087f08fa}">
